+
+/**
+ * Remove a weak reference from a WeakMap/WeakSet to a symbol key.
+ *
+ * This is the symbol analog of ecma_op_object_unref_weak. When the symbol's back-list
+ * becomes empty its row is released and the table slot is marked empty for reuse.
+ */
+void
+ecma_op_container_symbol_unref_weak (ecma_string_t *symbol_p, /**< symbol key */
+                                     ecma_value_t ref_holder) /**< container object value */
+{
+  uint32_t row_index;
+  ecma_collection_t *refs_p = ecma_op_container_symbol_find_weak_refs (symbol_p, &row_index);
+
+  if (refs_p == NULL)
+  {
+    return;
+  }
+
+  bool any_remaining = false;
+  bool removed = false;
+
+  for (uint32_t i = 0; i < refs_p->item_count; i++)
+  {
+    if (!removed && refs_p->buffer_p[i] == ref_holder)
+    {
+      refs_p->buffer_p[i] = ECMA_VALUE_EMPTY;
+      removed = true;
+      continue;
+    }
+
+    if (!ecma_is_value_empty (refs_p->buffer_p[i]))
+    {
+      any_remaining = true;
+    }
+  }
+
+  if (!any_remaining)
+  {
+    ecma_collection_t *table_p = JERRY_CONTEXT (symbol_weak_refs_p);
+
+    ecma_collection_destroy (refs_p);
+    table_p->buffer_p[row_index] = ECMA_VALUE_EMPTY;
+    table_p->buffer_p[row_index + 1] = ECMA_VALUE_EMPTY;
+  }
+} /* ecma_op_container_symbol_unref_weak */
+
+/**
+ * Remove every WeakMap/WeakSet entry keyed by a symbol that is about to be freed.
+ *
+ * Symbols are reference counted rather than garbage collected, so this hook runs from the
+ * symbol's destructor the moment its last strong reference is released. It walks the
+ * symbol's back-list, removes the corresponding entry from each container, and releases the
+ * back-list. Collection of symbol-keyed entries is therefore deterministic and immediate.
+ */
+void
+ecma_op_container_symbol_clear_weak (ecma_string_t *symbol_p) /**< symbol key */
+{
+  uint32_t row_index;
+  ecma_collection_t *refs_p = ecma_op_container_symbol_find_weak_refs (symbol_p, &row_index);
+
+  if (refs_p == NULL)
+  {
+    return;
+  }
+
+  const ecma_value_t symbol_value = ecma_make_symbol_value (symbol_p);
+
+  for (uint32_t i = 0; i < refs_p->item_count; i++)
+  {
+    if (ecma_is_value_empty (refs_p->buffer_p[i]))
+    {
+      continue;
+    }
+
+    ecma_op_container_remove_weak_entry (ecma_get_object_from_value (refs_p->buffer_p[i]), symbol_value);
+  }
+
+  ecma_collection_t *table_p = JERRY_CONTEXT (symbol_weak_refs_p);
+
+  ecma_collection_destroy (refs_p);
+  table_p->buffer_p[row_index] = ECMA_VALUE_EMPTY;
+  table_p->buffer_p[row_index + 1] = ECMA_VALUE_EMPTY;
+} /* ecma_op_container_symbol_clear_weak */
