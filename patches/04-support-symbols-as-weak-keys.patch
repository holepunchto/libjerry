+ecma_op_container_symbol_set_weak (ecma_string_t *symbol_p, /**< symbol key */
+                                   ecma_object_t *object_p) /**< container object */
+{
+  ecma_collection_t *table_p = JERRY_CONTEXT (symbol_weak_refs_p);
+
+  if (table_p == NULL)
+  {
+    table_p = ecma_new_collection ();
+    JERRY_CONTEXT (symbol_weak_refs_p) = table_p;
+  }
+
+  ecma_collection_t *refs_p = ecma_op_container_symbol_find_weak_refs (symbol_p, NULL);
+
+  if (refs_p == NULL)
+  {
+    refs_p = ecma_new_collection ();
+
+    const ecma_value_t symbol_value = ecma_make_symbol_value (symbol_p);
+    ecma_value_t refs_value;
+    ECMA_SET_INTERNAL_VALUE_POINTER (refs_value, refs_p);
+
+    /* Reuse an empty row left behind by a previously cleared symbol if one is available. */
+    bool row_reused = false;
