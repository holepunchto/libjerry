+static inline bool
+ecma_op_container_is_weak (lit_magic_string_id_t lit_id) /**< class id */
+{
+  return lit_id == LIT_MAGIC_STRING_WEAKMAP_UL || lit_id == LIT_MAGIC_STRING_WEAKSET_UL;
+} /* ecma_op_container_is_weak */
+
+/**
+ * Copy a key for storage in the internal buffer.
+ *
+ * Keys of a weak container are held weakly: object keys are tracked through their
+ * [[WeakRefs]] internal property and symbol keys through the symbol weak reference side
+ * table, so neither is reference counted by the buffer. Keys of a non-weak container are
+ * held strongly and are reference counted as usual.
+ *
+ * @return the value to store in the internal buffer
+ */
+static ecma_value_t
+ecma_op_internal_buffer_copy_key (ecma_value_t key_arg, /**< key argument */
+                                  lit_magic_string_id_t lit_id) /**< class id */
+{
+  if (ecma_op_container_is_weak (lit_id) && ecma_is_value_symbol (key_arg))
+  {
+    return key_arg;
+  }
+
+  return ecma_copy_value_if_not_object (key_arg);
+} /* ecma_op_internal_buffer_copy_key */
+
+/**
+ * Release a key stored in the internal buffer.
+ *
+ * The inverse of ecma_op_internal_buffer_copy_key: a weakly-held symbol key was stored
+ * without a reference, so it must not be released here.
+ */
+static void
+ecma_op_internal_buffer_free_key (ecma_value_t key_arg, /**< key argument */
+                                  lit_magic_string_id_t lit_id) /**< class id */
+{
+  if (ecma_op_container_is_weak (lit_id) && ecma_is_value_symbol (key_arg))
+  {
+    return;
+  }
+
+  ecma_free_value_if_not_object (key_arg);
+} /* ecma_op_internal_buffer_free_key */
+
+/**
+ * Find the weak reference back-list of a symbol in the side table.
+ *
+ * The side table maps a weakly-held symbol key to the list of WeakMap/WeakSet objects that
+ * reference it, mirroring the [[WeakRefs]] internal property attached to object keys.
+ *
+ * @return pointer to the back-list, or NULL if the symbol has no entry; if found and
+ *         row_index_p is not NULL, the row index of the symbol in the table is written to it
+ */
+static ecma_collection_t *
+ecma_op_container_symbol_find_weak_refs (ecma_string_t *symbol_p, /**< symbol key */
+                                         uint32_t *row_index_p) /**< [out] row index, optional */
+{
+  ecma_collection_t *table_p = JERRY_CONTEXT (symbol_weak_refs_p);
+
+  if (table_p == NULL)
+  {
+    return NULL;
+  }
+
+  const ecma_value_t symbol_value = ecma_make_symbol_value (symbol_p);
+
+  for (uint32_t i = 0; i < table_p->item_count; i += 2)
+  {
+    if (table_p->buffer_p[i] == symbol_value)
+    {
+      if (row_index_p != NULL)
+      {
+        *row_index_p = i;
+      }
+
+      return ECMA_GET_INTERNAL_VALUE_POINTER (ecma_collection_t, table_p->buffer_p[i + 1]);
+    }
+  }
+
+  return NULL;
+} /* ecma_op_container_symbol_find_weak_refs */
+
+/**
+ * Register a weak reference from a WeakMap/WeakSet to a symbol key.
