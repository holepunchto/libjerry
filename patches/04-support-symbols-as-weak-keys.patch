+/**
+ * Check whether a value can be used as a key of a weak container (WeakMap/WeakSet).
+ *
+ * Both objects and unique symbols can be held weakly. Registered (global) symbols and
+ * well-known symbols live forever in a global registry, so holding them weakly would be
+ * pointless; matching the CanBeHeldWeakly abstract operation, they are not accepted.
+ *
+ * @return true if the value can be used as a weak key, false otherwise
+ */
+static inline bool
+ecma_op_container_key_can_be_held_weakly (ecma_value_t key_arg) /**< key argument */
+{
+  if (ecma_is_value_object (key_arg))
+  {
+    return true;
+  }
+
+  if (ecma_is_value_symbol (key_arg))
+  {
+    return (ecma_get_symbol_from_value (key_arg)->u.hash & ECMA_SYMBOL_FLAG_GLOBAL) == 0;
+  }
+
+  return false;
+} /* ecma_op_container_key_can_be_held_weakly */
+
+/**
+ * Check whether a container holds its keys weakly (i.e. it is a WeakMap or WeakSet).
+ *
+ * @return true if the container is weak, false otherwise
