+    for (uint32_t i = 0; i < table_p->item_count; i += 2)
+    {
+      if (ecma_is_value_empty (table_p->buffer_p[i]))
+      {
+        table_p->buffer_p[i] = symbol_value;
+        table_p->buffer_p[i + 1] = refs_value;
+        row_reused = true;
+        break;
+      }
+    }
+
+    if (!row_reused)
+    {
+      ecma_collection_push_back (table_p, symbol_value);
+      ecma_collection_push_back (table_p, refs_value);
+    }
+  }
+
+  const ecma_value_t ref_holder = ecma_make_object_value (object_p);
+
+  for (uint32_t i = 0; i < refs_p->item_count; i++)
+  {
+    if (ecma_is_value_empty (refs_p->buffer_p[i]))
+    {
+      refs_p->buffer_p[i] = ref_holder;
+      return;
+    }
+  }
+
+  ecma_collection_push_back (refs_p, ref_holder);
